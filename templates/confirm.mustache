{{!
    @template mod_grouptool/confirm

    Back button helper to link to a different URL.

    Example context (json):
    {
    }
}}
<div class="modal modal-dialog modal-in-page show" id="notice">
    <div class="modal-content">
        <div class="modal-header">
            <h4>{{#str}} confirm, core {{/str}}</h4>
        </div>

        <div class="modal-body">
            <p>{{{message}}}</p>
        </div>

        <div class="modal-footer">
            <div class="buttons">
                {{{continuebutton}}}
                {{#cancelbutton}}
                    {{{cancelbutton}}}
                {{/cancelbutton}}
            </div>
        </div>
    </div>
</div>
